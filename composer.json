{
    "name": "jtl/nachricht",
    "description": "Nachricht is a distributed event queue system",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "8.3.* || 8.4.* || 8.5.*",
        "ext-json": "*",
        "ext-pcntl": "*",
        "jtl/php-generic-collection": " ^1.0.1",
        "nikic/php-parser": "^5.7",
        "psr/container": "^2.0.2",
        "psr/event-dispatcher": "^1.0",
        "psr/log": "^3.0.2",
        "ramsey/uuid": "^4.9.2",
        "symfony/config": "^7.4.10"
    },
    "suggest" : {
        "symfony/dependency-injection": "Recommended DI-Container",
        "symfony/yaml": "Required for Symfony DI-Container and examples",
        "php-amqplib/php-amqplib": "Required for RabbitMq Transport",
        "monolog/monolog": "Required when using AmqpEmitter / Consumer"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95.8",
        "mockery/mockery": "^1.6.12",
        "php-amqplib/php-amqplib": "^3.7.4",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.5.30",
        "rector/rector": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "JTL\\Nachricht\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JTL\\Nachricht\\": "tests/",
            "JTL\\Nachricht\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts" : {
        "phpcs": [
            "vendor/bin/php-cs-fixer fix --config=./.php-cs-fixer.dist.php"
        ],
        "phpcs-dry": [
            "vendor/bin/php-cs-fixer fix --config=./.php-cs-fixer.dist.php --dry-run"
        ],
        "phpstan": [
            "vendor/bin/phpstan analyse -c phpstan.neon"
        ],
        "phpunit": [
            "vendor/bin/phpunit -c phpunit.xml"
        ]
    }
}
